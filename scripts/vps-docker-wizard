#!/usr/bin/env bash
set -euo pipefail

die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

repo_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$repo_dir"

if [[ -f /etc/os-release ]]; then
  # shellcheck disable=SC1091
  . /etc/os-release
  case " ${ID:-} ${ID_LIKE:-} " in
    *" debian "* | *" ubuntu "*) ;;
    *) die "this wizard supports Debian and Ubuntu hosts" ;;
  esac
fi

prompt() {
  local label="$1"
  local default="${2:-}"
  local value
  if [[ -n "$default" ]]; then
    read -r -p "$label [$default]: " value
    printf '%s\n' "${value:-$default}"
  else
    read -r -p "$label: " value
    printf '%s\n' "$value"
  fi
}

prompt_required() {
  local label="$1"
  local default="${2:-}"
  local value
  while true; do
    value="$(prompt "$label" "$default")"
    if [[ -n "$value" ]]; then
      printf '%s\n' "$value"
      return
    fi
    printf 'Please enter a value.\n' >&2
  done
}

prompt_secret() {
  local label="$1"
  local value
  while true; do
    read -r -s -p "$label: " value
    printf '\n' >&2
    if [[ -n "$value" ]]; then
      printf '%s\n' "$value"
      return
    fi
    printf 'Please enter a value.\n' >&2
  done
}

prompt_secret_confirm() {
  local label="$1"
  local value confirm
  while true; do
    read -r -s -p "$label: " value
    printf '\n' >&2
    if [[ -z "$value" ]]; then
      printf 'Please enter a value.\n' >&2
      continue
    fi
    read -r -s -p "$label (again): " confirm
    printf '\n' >&2
    if [[ "$value" == "$confirm" ]]; then
      printf '%s\n' "$value"
      return
    fi
    printf 'Passwords did not match. Try again.\n' >&2
  done
}

confirm() {
  local label="$1"
  local default="${2:-n}"
  local suffix="[y/N]"
  local value
  if [[ "$default" == "y" ]]; then
    suffix="[Y/n]"
  fi
  read -r -p "$label $suffix: " value
  value="${value:-$default}"
  case "$value" in
    y | Y | yes | YES) return 0 ;;
    *) return 1 ;;
  esac
}

prompt_choice() {
  local label="$1"
  local default="$2"
  local value
  while true; do
    value="$(prompt "$label" "$default")"
    case "$value" in
      ollama | openrouter)
        printf '%s\n' "$value"
        return
        ;;
      *)
        printf 'Please enter ollama or openrouter.\n' >&2
        ;;
    esac
  done
}

shell_quote() {
  printf "'%s'" "$(printf '%s' "$1" | sed "s/'/'\\\\''/g")"
}

write_env() {
  local key="$1"
  local value="$2"
  printf '%s=%s\n' "$key" "$(shell_quote "$value")" >> "$env_file"
}

runtime_available() {
  case "$1" in
    docker) command -v docker >/dev/null 2>&1 && sudo docker compose version >/dev/null 2>&1 ;;
    nerdctl) command -v nerdctl >/dev/null 2>&1 && sudo nerdctl compose version >/dev/null 2>&1 ;;
    podman) command -v podman >/dev/null 2>&1 && sudo podman compose version >/dev/null 2>&1 ;;
    *) return 1 ;;
  esac
}

runtime_names() {
  case "$1" in
    docker) sudo docker ps -a --format '{{.Names}}' ;;
    nerdctl) sudo nerdctl ps -a --format '{{.Names}}' ;;
    podman) sudo podman ps -a --format '{{.Names}}' ;;
    *) return 1 ;;
  esac
}

runtime_remove() {
  local runtime="$1"
  shift
  case "$runtime" in
    docker) sudo docker rm -f "$@" ;;
    nerdctl) sudo nerdctl rm -f "$@" ;;
    podman) sudo podman rm -f "$@" ;;
    *) return 1 ;;
  esac
}

printf 'Bunnyland VPS Docker setup wizard\n'
printf 'This writes compose.user.yml through scripts/vps-docker-setup and starts the containers.\n\n'

available=()
for runtime in docker nerdctl podman; do
  if runtime_available "$runtime"; then
    available+=("$runtime")
  fi
done

if [[ ${#available[@]} -eq 0 ]]; then
  runtime="nerdctl"
  printf 'No supported Compose runtime was found. The setup script will install nerdctl.\n'
else
  printf 'Available container runtimes: %s\n' "${available[*]}"
  runtime="$(prompt "Container runtime" "${available[0]}")"
  case " ${available[*]} " in
    *" $runtime "*) ;;
    *) die "$runtime is not available with compose support" ;;
  esac
fi

if runtime_available "$runtime"; then
  mapfile -t existing < <(runtime_names "$runtime" | grep -E '^bunnyland-(server|frontend)-1$' || true)
  if [[ ${#existing[@]} -gt 0 ]]; then
    printf '\nExisting Bunnyland containers were found:\n'
    printf '  %s\n' "${existing[@]}"
    printf 'Removing these containers does not delete bind-mounted data or named volumes.\n'
    printf 'The setup script also backs up the selected world save before starting.\n'
    if confirm "Remove existing Bunnyland containers before setup?" "n"; then
      runtime_remove "$runtime" "${existing[@]}"
    else
      die "leaving existing containers in place; stop or remove them before rerunning setup"
    fi
  fi
fi

domain="$(prompt_required "Sandbox domain" "sandbox.example.com")"
data_dir="$(prompt_required "Host data directory" "/var/lib/bunnyland")"
admin_user="$(prompt_required "Admin username" "editor")"
admin_password="$(prompt_secret_confirm "Admin password")"
cert_email="$(prompt "Let's Encrypt email (blank is allowed)")"
world_save="$(prompt "Existing world save path (blank to generate/use data-dir default)")"
favicon_file="$(prompt "Custom favicon path (blank for default)")"
home_domain="$(prompt "Homepage domain served by this frontend container (blank to skip)")"
home_dir=""
home_cert_name=""
if [[ -n "$home_domain" ]]; then
  home_dir="$(prompt_required "Homepage files directory" "/opt/bunnyland/home")"
  home_cert_name="$(prompt "Homepage certificate name" "$home_domain")"
fi

full_deployment=0
if confirm "Set up the full Bunnyland deployment with an LLM provider and Discord now?" "y"; then
  full_deployment=1
else
  printf 'Continuing with a container/routing smoke test only. This is not a full Bunnyland deployment.\n'
fi

enable_llm=0
llm_provider="ollama"
ollama_key=""
ollama_host=""
openrouter_key=""
openrouter_server_url=""
worldgen_model="deepseek-v4-pro"
character_model="deepseek-v4-flash"
if [[ "$full_deployment" == "1" ]]; then
  enable_llm=1
  llm_provider="$(prompt_choice "LLM provider for world generation and characters (ollama/openrouter)" "$llm_provider")"
  case "$llm_provider" in
    ollama)
      ollama_key="$(prompt_secret "OLLAMA_CLOUD_API_KEY")"
      ollama_host="$(prompt "Ollama endpoint override (blank for https://ollama.com)")"
      ;;
    openrouter)
      openrouter_key="$(prompt_secret "OPENROUTER_API_KEY")"
      openrouter_server_url="$(prompt "OpenRouter endpoint override (blank for SDK default)")"
      worldgen_model="openai/gpt-4.1"
      character_model="openai/gpt-4.1-mini"
      ;;
  esac
  worldgen_model="$(prompt "Worldgen model" "$worldgen_model")"
  character_model="$(prompt "Character model" "$character_model")"
fi

enable_discord=0
discord_token=""
discord_user_id=""
discord_channel_id=""
discord_character=""
if [[ "$full_deployment" == "1" ]]; then
  enable_discord=1
  discord_token="$(prompt_secret "DISCORD_TOKEN")"
  discord_user_id="$(prompt "Startup Discord user id (blank to use !claim)")"
  discord_channel_id="$(prompt "Startup Discord channel id (blank if not assigning a user)")"
  discord_character="$(prompt "Startup character name (blank for first claimable character)")"
fi

env_file="$(mktemp)"
chmod 0600 "$env_file"
trap 'rm -f "$env_file"' EXIT

write_env BUNNYLAND_CONTAINER_RUNTIME "$runtime"
write_env BUNNYLAND_DOMAIN "$domain"
write_env BUNNYLAND_DATA_DIR "$data_dir"
write_env BUNNYLAND_ADMIN_USER "$admin_user"
write_env BUNNYLAND_ADMIN_PASSWORD "$admin_password"
write_env BUNNYLAND_ENABLE_LLM "$enable_llm"
write_env BUNNYLAND_ENABLE_DISCORD "$enable_discord"
if [[ -n "$cert_email" ]]; then write_env BUNNYLAND_CERT_EMAIL "$cert_email"; fi
if [[ -n "$world_save" ]]; then write_env BUNNYLAND_WORLD_SAVE "$world_save"; fi
if [[ -n "$favicon_file" ]]; then write_env BUNNYLAND_FAVICON_FILE "$favicon_file"; fi
if [[ -n "$home_domain" ]]; then
  write_env BUNNYLAND_HOME_DOMAIN "$home_domain"
  write_env BUNNYLAND_HOME_CERT_NAME "$home_cert_name"
  write_env BUNNYLAND_HOME_DIR "$home_dir"
fi
if [[ "$enable_llm" == "1" ]]; then
  write_env BUNNYLAND_LLM_PROVIDER "$llm_provider"
  write_env BUNNYLAND_WORLDGEN_PROVIDER "$llm_provider"
  case "$llm_provider" in
    ollama)
      write_env OLLAMA_CLOUD_API_KEY "$ollama_key"
      if [[ -n "$ollama_host" ]]; then write_env OLLAMA_HOST "$ollama_host"; fi
      ;;
    openrouter)
      write_env OPENROUTER_API_KEY "$openrouter_key"
      if [[ -n "$openrouter_server_url" ]]; then
        write_env OPENROUTER_SERVER_URL "$openrouter_server_url"
      fi
      ;;
  esac
  write_env BUNNYLAND_WORLDGEN_MODEL "$worldgen_model"
  write_env BUNNYLAND_CHARACTER_MODEL "$character_model"
fi
if [[ "$enable_discord" == "1" ]]; then
  write_env DISCORD_TOKEN "$discord_token"
  if [[ -n "$discord_user_id" ]]; then write_env BUNNYLAND_DISCORD_USER_ID "$discord_user_id"; fi
  if [[ -n "$discord_channel_id" ]]; then write_env BUNNYLAND_DISCORD_CHANNEL_ID "$discord_channel_id"; fi
  if [[ -n "$discord_character" ]]; then write_env BUNNYLAND_DISCORD_CHARACTER "$discord_character"; fi
fi

dns_line() {
  local name="$1" resolved public
  resolved="$(getent ahosts "$name" 2>/dev/null | awk '{print $1}' | sort -u | paste -sd, -)"
  if [[ -z "$resolved" ]]; then
    printf 'does not resolve yet (certbot will fail until a DNS A record points here)'
    return
  fi
  public="$(curl -fsS --max-time 5 https://api.ipify.org 2>/dev/null || true)"
  if [[ -n "$public" ]]; then
    if printf '%s' "$resolved" | tr ',' '\n' | grep -qxF "$public"; then
      printf 'resolves to %s (matches this server)' "$resolved"
    else
      printf 'resolves to %s but this server looks like %s — check the DNS A record' "$resolved" "$public"
    fi
  else
    printf 'resolves to %s' "$resolved"
  fi
}

printf '\nReview these settings before setup starts:\n'
printf '  Container runtime : %s\n' "$runtime"
printf '  Public domain     : %s\n' "$domain"
printf '  DNS check         : %s\n' "$(dns_line "$domain")"
printf '  Data directory    : %s\n' "$data_dir"
printf '  Admin username    : %s\n' "$admin_user"
printf '  Admin password    : (set)\n'
printf '  Let'\''s Encrypt email: %s\n' "${cert_email:-(none, registering without email)}"
if [[ -n "$world_save" ]]; then printf '  Existing world    : %s\n' "$world_save"; fi
if [[ -n "$favicon_file" ]]; then printf '  Custom favicon    : %s\n' "$favicon_file"; fi
if [[ -n "$home_domain" ]]; then
  printf '  Homepage domain   : %s\n' "$home_domain"
  printf '  Homepage DNS check: %s\n' "$(dns_line "$home_domain")"
  printf '  Homepage files    : %s\n' "$home_dir"
fi
if [[ "$full_deployment" == "1" ]]; then
  printf '  Mode              : full deployment (%s + Discord)\n' "$llm_provider"
  printf '  LLM provider      : %s\n' "$llm_provider"
  case "$llm_provider" in
    ollama)
      printf '  Ollama endpoint   : %s\n' "${ollama_host:-https://ollama.com}"
      printf '  Ollama API key    : (set)\n'
      ;;
    openrouter)
      printf '  OpenRouter endpoint: %s\n' "${openrouter_server_url:-(SDK default)}"
      printf '  OpenRouter API key: (set)\n'
      ;;
  esac
  printf '  Worldgen model    : %s\n' "$worldgen_model"
  printf '  Character model   : %s\n' "$character_model"
  printf '  Discord token     : (set)\n'
  if [[ -n "$discord_user_id" ]]; then
    printf '  Discord startup   : user %s -> %s in channel %s\n' \
      "$discord_user_id" "${discord_character:-first claimable character}" "${discord_channel_id:-(none)}"
  fi
else
  printf '  Mode              : smoke test only (no LLM provider or Discord)\n'
fi
printf '\nThis installs packages, adds firewall rules, and requests a real Let'\''s Encrypt\n'
printf 'certificate (which is rate-limited), then starts the containers. If UFW is inactive,\n'
printf 'the setup script leaves it disabled and tells you how to enable it.\n'
if ! confirm "Proceed with these settings?" "y"; then
  die "aborted before setup; no changes were made to TLS, the firewall, or containers"
fi

printf '\nStarting setup with %s. Public TLS will use Let'\''s Encrypt.\n' "$runtime"
set -a
# shellcheck disable=SC1090
. "$env_file"
set +a
scripts/vps-docker-setup

printf '\nRun this verifier after DNS points at the VPS:\n'
printf '  BUNNYLAND_DOMAIN=%s BUNNYLAND_ADMIN_USER=%s BUNNYLAND_ADMIN_PASSWORD=<password> scripts/vps-docker-verify\n' "$domain" "$admin_user"
