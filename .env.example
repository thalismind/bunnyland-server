# Local/development environment example. The VPS Docker setup writes
# compose.user.yml instead of using .env.

BUNNYLAND_DATA_DIR=./data
BUNNYLAND_SERVER_TAG=main
BUNNYLAND_WEB_TAG=main
BUNNYLAND_CONTAINER_RUNTIME=nerdctl
BUNNYLAND_TLS=1
BUNNYLAND_CONFIGURE_FIREWALL=1
BUNNYLAND_HTTP_BIND=0.0.0.0:80
BUNNYLAND_SERVER_NAME=_
BUNNYLAND_GENERATOR=lifesim-demo
BUNNYLAND_WORLD_FILE=/data/worlds/main.json
BUNNYLAND_TICK_SECONDS=30
BUNNYLAND_TIME_SCALE=1800
BUNNYLAND_AUTOSAVE_EVERY=20
BUNNYLAND_ENABLE_LLM=1
BUNNYLAND_ENABLE_DISCORD=1

# Required for a full Bunnyland deployment. Set BUNNYLAND_ENABLE_LLM=0 only for a
# container/routing smoke test.
# OLLAMA_CLOUD_API_KEY=sk-...
OLLAMA_HOST=https://ollama.com
BUNNYLAND_WORLDGEN_MODEL=deepseek-v4-pro
BUNNYLAND_CHARACTER_MODEL=deepseek-v4-flash

# Required for a full Bunnyland deployment. Set BUNNYLAND_ENABLE_DISCORD=0 only for a
# container/routing smoke test.
# DISCORD_TOKEN=...

# Optional startup Discord claim for the full deployment.
# BUNNYLAND_DISCORD_USER_ID=123
# BUNNYLAND_DISCORD_CHANNEL_ID=456
# BUNNYLAND_DISCORD_CHARACTER=Juniper

# Image generation (ComfyUI). OFF unless COMFYUI_SERVER_URL is set. Characters then
# always get a portrait (and a toon sprite when toonsim is enabled); event images are
# generated on player request. Reuses OLLAMA_* for the prompt enhancer.
# COMFYUI_SERVER_URL=http://localhost:8188
# COMFYUI_USE_WEBSOCKET=1
# COMFYUI_POLL_INTERVAL_SECONDS=1
# COMFYUI_TIMEOUT_SECONDS=120
# BUNNYLAND_MEDIA_DIR=/data/media
# Workflow family (base model): anima (default, lowest VRAM), sdxl, klein, flux2dev (best).
# A suffix is allowed for your own label, e.g. anima-my-server -> anima base.
# BUNNYLAND_IMAGE_WORKFLOWS=anima
# Force a prompt style for every job ("tag" or "natural"); blank uses the family default.
# BUNNYLAND_IMAGE_PROMPT_STYLE=
# BUNNYLAND_IMAGE_TEMPLATES=/data/image-workflows.json
# BUNNYLAND_IMAGE_ENHANCER=stub
# BUNNYLAND_IMAGE_BACKFILL_SECONDS=5
# Required only for Discord character avatars (they need an absolute, reachable URL):
# BUNNYLAND_PUBLIC_BASE_URL=https://sandbox.example.com

# For generated compose.user.yml TLS settings:
# Set these two values to change the public HTTPS domain.
# BUNNYLAND_SERVER_NAME=sandbox.example.com
# BUNNYLAND_CERT_NAME=sandbox.example.com
# BUNNYLAND_HTTP_BIND=0.0.0.0:80
# BUNNYLAND_HTTPS_BIND=0.0.0.0:443
# BUNNYLAND_LETSENCRYPT_DIR=/etc/letsencrypt
# BUNNYLAND_TEMPO_AUTH_DIR=/etc/nginx/bunnyland-tempo
# BUNNYLAND_FAVICON_FILE=/opt/bunnyland/favicon.png
# BUNNYLAND_HOME_DOMAIN=bunnyland.dev
# BUNNYLAND_HOME_CERT_NAME=bunnyland.dev
# BUNNYLAND_HOME_DIR=/opt/bunnyland/home
