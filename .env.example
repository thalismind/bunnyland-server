BUNNYLAND_DATA_DIR=./data
BUNNYLAND_HTTP_BIND=0.0.0.0:80
BUNNYLAND_SERVER_NAME=_
BUNNYLAND_GENERATOR=lifesim-demo
BUNNYLAND_TICK_SECONDS=30
BUNNYLAND_TIME_SCALE=1800
BUNNYLAND_AUTOSAVE_EVERY=20

# For compose.tls.yml:
# Set these two values to change the public HTTPS domain.
# BUNNYLAND_SERVER_NAME=sandbox.example.com
# BUNNYLAND_CERT_NAME=sandbox.example.com
# BUNNYLAND_HTTP_BIND=0.0.0.0:80
# BUNNYLAND_HTTPS_BIND=0.0.0.0:443
# BUNNYLAND_LETSENCRYPT_DIR=/etc/letsencrypt
# BUNNYLAND_NGINX_AUTH_DIR=/etc/nginx/bunnyland
